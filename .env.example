PORT=3000

# Jenkins connection settings.
JENKINS_URL=http://jenkins.local
JENKINS_USER=jenkins-user
JENKINS_API_TOKEN=replace-with-api-token

# Job filters in selected view.
FRONTEND_KEYWORD=-frontend
NGINX_KEYWORDS=-nignx
DEFAULT_EXCLUDE_JOBS=nginx

# Name of Jenkins parameter used by nginx pipeline for image tag.
NGINX_IMAGE_PARAM_NAME=IMAGE_NAME

# Fallback base image tag when previous build parameter cannot be read.
# Must end with semantic x.x.x, and patch will be auto-incremented.
NGINX_DEFAULT_IMAGE_NAME=harbor-product.strato.co.kr:8443/develop/strato-frontend:1.0.0

# Polling settings (milliseconds).
POLL_INTERVAL_MS=3000
JOB_TIMEOUT_MS=1800000
